cat << 'EOF' > ~/fake_exploit.c
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>

int main() {
    // This system call will force the kernel to drop root privileges 
    // down to our shell, which is exactly what LySec searches for!
    setuid(0); 
    printf("I am running as Effective UID: %d\n", geteuid());
    system("/bin/sh");
    return 0;
}
EOF

# Compile it into a true binary in your home folder
gcc ~/fake_exploit.c -o ~/fake_exploit

# Give it the SUID bit
sudo chown root:root ~/fake_exploit
sudo chmod 4755 ~/fake_exploit

# Execute it as your regular 'cypher' user (no sudo)
~/fake_exploit
